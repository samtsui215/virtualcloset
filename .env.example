# =============================================================================
# Virtual Closet — environment variables
# Copy to .env.local for local dev. On Vercel, set these in Project Settings →
# Environment Variables. Prisma CLI reads .env (see note at bottom).
# =============================================================================

# --- Database (Supabase Postgres) --------------------------------------------
# From Supabase: Project Settings → Database → Connection string.
#   DATABASE_URL  = the "Transaction" pooler URL (port 6543) + ?pgbouncer=true
#   DIRECT_URL    = the "Session"/direct URL (port 5432), used for migrations
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Image storage -----------------------------------------------------------
# "local"    → writes to ./public/uploads (dev only; not persisted on Vercel)
# "supabase" → uploads to a Supabase Storage bucket
STORAGE_DRIVER="supabase"
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""          # server-only secret — NEVER expose to client
SUPABASE_STORAGE_BUCKET="wardrobe"

# --- Firebase Auth: server (Admin SDK) ---------------------------------------
# From Firebase: Project Settings → Service accounts → Generate new private key.
# Paste the values from that JSON. Keep the \n escapes in the private key.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Firebase Auth: client (Web config) --------------------------------------
# From Firebase: Project Settings → General → Your apps → Web app config.
# These are NEXT_PUBLIC_ (shipped to the browser) — not secret by design.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="<ref>.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="<ref>.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# -----------------------------------------------------------------------------
# Note: Prisma CLI only reads .env (not .env.local). Mirror DATABASE_URL and
# DIRECT_URL into a .env file too, or run migrations with `dotenv -e .env.local`.
# -----------------------------------------------------------------------------
